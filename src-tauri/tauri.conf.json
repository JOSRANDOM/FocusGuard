{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FocusGuard",
  "version": "1.2.0",
  "identifier": "com.josephmoriherrera.focusguard",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FocusGuard",
        "width": 900,
        "height": 650,
        "minWidth": 700,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc1RDMxNTU1MTZGMDNENjcKUldSblBmQVdWUlhUZFZNRkNTS040OFo1NGxMMmhXSmZjRlJuZ2M5ZzNOeFlsaFdRL21lNW9BaVAK",
      "endpoints": [
        "https://github.com/JOSRANDOM/FocusGuard/releases/latest/download/latest.json"
      ]
    }
  }
}
